  "keyFeatures": [
    "Joint and problem management for tracking body areas and associated conditions",
    "Exercise library with images, videos, difficulty levels, and detailed instructions",
    "Multi-dimensional exercise categorization (body area, type, position, movement, equipment)",
    "Patient prescription system with customizable exercise parameters per patient",
    "React-based dashboard frontend with real-time data via TanStack Query",
    "SQLite/PostgreSQL/MySQL database support via SQLAlchemy",
    "Custom category creation for extending default classification taxonomies",
    "Swagger UI and ReDoc auto-generated API documentation"
  ],
  "publicApiSurface": [
